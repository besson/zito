# Copy to .env and fill in. .env is gitignored.

# W&B — sign up at https://wandb.ai, then Settings > API keys
WANDB_API_KEY=
WANDB_PROJECT=zito-listingiq

# MLflow — local, no account needed. `make tracking-up` serves the UI at this URI.
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=zito-listingiq

# GCP (Week 2+, GPU runs)
GOOGLE_CLOUD_PROJECT=
